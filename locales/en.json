  "about": {
    "eyebrow": "About",
    "intro": "BRUT is a science-based fuelling and training companion for endurance athletes. We make electrolyte capsules and build the digital tools that tell you when and how to take them.",
    "what_we_make_title": "What we make",
    "what_we_make_p1": "BRUT capsules deliver 211 mg of sodium each — calibrated for the losses real endurance athletes face, not generic sports-drink assumptions.",
    "what_we_make_p2": "Around the capsules we build deterministic planning tools: single-session fuelling (BRUT TRAIN), full periodised race programmes (BRUT RACE) and complete race-day strategies (BRUT RACE DAY).",
    "how_we_plan_title": "How we plan",
    "how_we_plan_body": "Methodology over magic. Polarised 80/20 training (Seiler), carb periodisation through phases, hydration grounded in physiological baselines (Baker 2017, Barnes 2019, ACSM). Every recommendation comes from a pure function with the assumptions visible.",
    "what_we_are_not_title": "What we are not",
    "what_we_are_not_body": "We are not a coach. We are not medical advice. Our plans are a structured starting point you adapt with experience, sensation and professional guidance.",
    "find_us_title": "Find us",
    "find_us_body": "Email <mail>hello@brutfuel.com</mail> or pick up capsules at <shop>brutfuel.com</shop>.",
    "references": "References: Baker LB 2017 · Barnes et al. 2019 · Seiler 2010 · ACSM 2007",
